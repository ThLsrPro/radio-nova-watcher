# ── Groq API — Transcription audio ───────────────────────────────────────────
# Clé API Groq (https://console.groq.com → API Keys)
GROQ_API_KEY=gsk_...

# ── ntfy.sh — Notifications push ─────────────────────────────────────────────
# Nom unique de votre topic (choisissez quelque chose d'imprévisible)
NTFY_TOPIC=radionova-alerte-thomas

# URL du serveur ntfy — laisser la valeur par défaut pour utiliser ntfy.sh public,
# ou pointer vers votre instance auto-hébergée (ex: https://ntfy.monserveur.fr)
NTFY_SERVER=https://ntfy.sh

# ── GitHub Gist — Archivage et dashboard ─────────────────────────────────────
# Token GitHub avec le scope "gist" uniquement
# Créer sur : github.com → Settings → Developer settings → Personal access tokens
# Cocher uniquement le scope : gist
GIST_TOKEN=ghp_...

# Mettre "true" pour activer l'archivage, "false" pour le désactiver
GIST_ENABLED=false

# ── Flux radio ────────────────────────────────────────────────────────────────
# URL du flux audio live de Radio Nova (ne pas modifier sauf changement de flux)
RADIO_STREAM_URL=http://radionova.ice.infomaniak.ch/radionova-256.aac

# ── Capture audio ─────────────────────────────────────────────────────────────
# Durée en secondes de chaque chunk audio transmis à Groq pour transcription
CHUNK_DURATION_SECONDS=15

# ── Détection ─────────────────────────────────────────────────────────────────
# Délai minimum (en minutes) entre deux notifications pour éviter les doublons
DETECTION_COOLDOWN_MINUTES=1
